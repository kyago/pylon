{
  "PostToolUse": [
    {
      "matcher": "Edit|Write",
      "hooks": [
        {
          "type": "command",
          "command": "pylon sync-memory --incremental --agent claude"
        }
      ]
    }
  ],
  "Stop": [
    {
      "matcher": "*",
      "hooks": [
        {
          "type": "command",
          "command": "pylon sync-memory --from-session --agent claude"
        }
      ]
    }
  ]
}
